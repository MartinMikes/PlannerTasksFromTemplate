# Power Platform environment settings
# Copy this file to .env and fill in your values.
# Never commit the .env file – it is listed in .gitignore.

# Power Platform environment URL
# Example: https://yourorg.crm4.dynamics.com/
PP_ENVIRONMENT_URL=

# Azure AD Application (client) ID of the service principal used by PAC CLI and GitHub Actions deployment
PP_APP_ID=

# Client secret of the service principal
PP_CLIENT_SECRET=

# Azure AD Tenant ID
PP_TENANT_ID=

# Application (client) ID of the Entra app registration used by the Campanula Planner Graph custom connector
# for delegated Microsoft Graph OAuth. This is a separate app from PP_APP_ID.
# Required: delegated Graph permission Tasks.ReadWrite.
# Example: 00000000-0000-0000-0000-000000000000
PP_CONNECTOR_APP_ID=

# SharePoint site URL where PlannerTasksTemplate.xlsx is stored
# Example: https://yourorg.sharepoint.com/sites/Campanula
SP_SITE_URL=

# SharePoint document library name (display name)
# Example: Planner Templates
SP_LIBRARY_NAME=
