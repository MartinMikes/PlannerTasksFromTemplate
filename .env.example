# Power Platform environment settings
# Copy this file to .env and fill in your values.
# Never commit the .env file – it is listed in .gitignore.

# Power Platform environment URL
# Example: https://yourorg.crm4.dynamics.com/
PP_ENVIRONMENT_URL=

# Azure AD Application (client) ID of the service principal
PP_APP_ID=

# Client secret of the service principal
PP_CLIENT_SECRET=

# Azure AD Tenant ID
PP_TENANT_ID=

# SharePoint site URL where PlannerTasksTemplate.xlsx is stored
# Example: https://yourorg.sharepoint.com/sites/Campanula
SP_SITE_URL=

# SharePoint document library name (display name)
# Example: Planner Templates
SP_LIBRARY_NAME=
