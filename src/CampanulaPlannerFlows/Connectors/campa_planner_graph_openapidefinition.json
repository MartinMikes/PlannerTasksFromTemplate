        },
        "category24": {
          "$ref": "#/definitions/PlannerCategoryDescription"
        },
        "category25": {
          "$ref": "#/definitions/PlannerCategoryDescription"
        }
      }
    },
    "PlannerCategoryDescription": {
      "type": "string",
      "description": "Planner label display name."
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "parameters": {
    "PlanId": {
      "name": "planId",
      "in": "path",
      "required": true,
      "type": "string",
      "description": "Planner plan identifier.",
      "x-ms-summary": "Plan ID",
      "x-ms-visibility": "important"
    },
    "IfMatch": {
      "name": "If-Match",
      "in": "header",
      "required": true,
      "type": "string",
      "description": "ETag from the immediately preceding plan-details read.",
      "x-ms-summary": "If-Match",
      "x-ms-visibility": "important"
    }
  },
  "responses": {
    "PlannerPlanDetailsGetResponse": {
      "description": "Planner plan details returned successfully.",
      "schema": {
        "$ref": "#/definitions/PlannerPlanDetails"
      }
    },
    "PlannerPlanDetailsUpdateResponse": {
      "description": "Planner plan details updated successfully.",
      "schema": {
        "$ref": "#/definitions/PlannerPlanDetails"
      }
    },
    "PlannerPlanDetailsNoContentResponse": {
      "description": "Planner plan details updated successfully."
    }
  },
  "securityDefinitions": {
    "oauth2_auth": {
      "type": "oauth2",
      "flow": "accessCode",
